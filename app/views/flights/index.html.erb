<div class="row justify-content-center">
  <div class="col-xl-6 col-md-8 col-sm-10 col-12">
    <div class="custom-index p-3">
      <h1 class="text-center mb-3"><%= t(".title") %></h1>

      <ul class="nav nav-tabs d-flex justify-content-center mb-3" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="upcoming-tab" data-bs-toggle="tab" data-bs-target="#upcoming-tab-pane" type="button" role="tab" aria-controls="upcoming-tab-pane" aria-selected="true">
            <%= t('.upcoming') %>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed-tab-pane" type="button" role="tab" aria-controls="completed-tab-pane" aria-selected="false">
            <%= t('.completed') %>
          </button>
        </li>
      </ul>
      <div class="tab-content" id="myTabContent">
        <div class="tab-pane fade show active" id="upcoming-tab-pane" role="tabpanel" aria-labelledby="upcoming-tab" tabindex="0">
          <% if @upcoming_flights.count == 0 %>
            <div class="flight-card d-flex flex-column mb-2 p-3">
              <h4 class="text-center text-secondary"><%= t('.no_flights') %> <i class="fa-regular fa-face-frown-open"></i></h4>
              <div class="form-footer d-flex justify-content-center align-items-center">
                <p class="mb-0 me-2"><%= t(".lets") %></p>
                <strong><%= link_to t(".add"), search_path %></strong>
              </div>
            </div>
          <% else %>
            <% @upcoming_flights.each do |flight| %>
              <%= render 'flight', flight: flight %>
            <% end %>
          <% end %>
        </div>
        <div class="tab-pane fade" id="completed-tab-pane" role="tabpanel" aria-labelledby="completed-tab" tabindex="0" data-controller="year-filter">
          <% if @completed_flights.count == 0 %>
            <div class="flight-card d-flex flex-column mb-2 p-3">
              <h4 class="text-center text-secondary"><%= t('.no_flights') %> <i class="fa-regular fa-face-frown-open"></i></h4>
              <div class="form-footer d-flex justify-content-center align-items-center">
                <p class="mb-0 me-2"><%= t(".lets") %></p>
                <strong><%= link_to t(".add"), search_path %></strong>
              </div>
            </div>
          <% else %>
            <div class="year-scroll mb-3">
              <div class="year-scroll-inner text-center">
                <span class="badge rounded-pill text-bg-primary me-1" role="button" data-action="click->year-filter#showAll" data-year-filter-target="badge">
                  <%= t('.all') %>
                </span>

                <% @years.each do |year| %>
                  <span class="badge rounded-pill text-bg-info text-white me-1" role="button" data-action="click->year-filter#filter" data-year="<%= year %>" data-year-filter-target="badge">
                    <%= year %>
                  </span>
                <% end %>
              </div>
            </div>

            <% @completed_flights_year.each do |year, flights| %>
              <div data-year-filter-target="group" data-year="<%= year %>">
                <% flights.each do |flight| %>
                  <%= render 'flight', flight: flight %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="modal fade" id="airportsByCountriesModal" tabindex="-1" aria-labelledby="airportsByCountriesModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg custom-modal">
    <div class="modal-content">
      <div class="modal-title d-flex justify-content-between align-items-center p-3">
        <h4 class="m-0 text-primary"><%= t(".title") %></h4>
        <i type="button" data-bs-dismiss="modal" aria-label="Close" class="close-icon fa-regular fa-circle-xmark"></i>
      </div>
      <div class="modal-info p-3">
        <div class="stats-card p-3 mb-2">

          <% @airport_stats.all_airports_by_countries.each do |country, count| %>
            <div class="row align-items-center border-bottom">
              <div class="col-1 d-flex justify-content-start align-items-center">
                <img src="<%= country.flag_url %>" alt="<%= country.code %>">
              </div>
              <div class="col d-flex align-items-center" style="min-width: 0;">
                <p class="my-1 text-truncate w-100 text-center"><%= country.name[I18n.locale.to_s] %></p>
              </div>
              <div class="col-1 d-flex justify-content-end align-items-center">
                <p class="my-1 text-secondary"><strong><%= count %></strong></p>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="flightsDurationModal" tabindex="-1" aria-labelledby="flightsDurationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg custom-modal">
    <div class="modal-content">
      <div class="modal-title d-flex justify-content-between align-items-center p-3">
        <h4 class="m-0 text-primary"><%= t(".title") %></h4>
        <i type="button" data-bs-dismiss="modal" aria-label="Close" class="close-icon fa-regular fa-circle-xmark"></i>
      </div>
      <div class="modal-info p-3">
        <div class="stats-card p-3 mb-2">
          <h4 class="text-center"><%= t(".top_longest_flights") %></h4>
          <% @flight_stats.top_desc_duration_flights.each do |flight| %>
            <div class="row align-items-center border-bottom">
              <div class="col d-flex justify-content-start align-items-center">
                <p class="my-1 text-secondary"><strong><%= flight.number %></strong></p>
              </div>
              <div class="col d-flex justify-content-center align-items-center">
                <p class="my-1"><%= flight.departure_airport.city %> - <%= flight.arrival_airport.city %></p>
              </div>
              <div class="col d-flex justify-content-end align-items-center">
                <p class="my-1 text-secondary"><strong><%= format_duration(flight.duration) %></strong></p>
              </div>
            </div>
          <% end %>
        </div>

        <div class="stats-card p-3 mb-2">
          <h4 class="text-center"><%= t(".top_shortest_flights") %></h4>
          <% @flight_stats.top_asc_duration_flights.each do |flight| %>
            <div class="row align-items-center border-bottom">
              <div class="col d-flex justify-content-start align-items-center">
                <p class="my-1 text-secondary"><strong><%= flight.number %></strong></p>
              </div>
              <div class="col d-flex justify-content-center align-items-center">
                <p class="my-1"><%= flight.departure_airport.city %> - <%= flight.arrival_airport.city %></p>
              </div>
              <div class="col d-flex justify-content-end align-items-center">
                <p class="my-1 text-secondary"><strong><%= format_duration(flight.duration) %></strong></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
